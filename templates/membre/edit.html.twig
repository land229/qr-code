{% extends 'base.html.twig' %}
{% block title %} Modifier membre {% endblock %}

{% block content %}
    <div class="nk-content ">
        {% block content_fluid %}
            <div class="container-fluid">
                {% block content_inner %}
                    <div class="nk-content-body">
                        {% embed 'admin/_partials/page_content.html.twig' %}
                            {% block page_title %}
                                Modifier le membre {{ membre.nom }} - {{ membre.prenom }}
                            {% endblock %}
                            {% block page_description %}
                                Vous etes sur le point de modifier ce membres de AFADOPA
                            {% endblock %}
                            {% block actions %}
                                <li><a href="{{ path('app_membre_index') }}"><button class="btn btn-primary">Retour</button></a></li>
                                <li>{{ include('membre/_delete_form.html.twig') }}</li>
                            {% endblock %}
                        {% endembed %}
                        {% block content_block %}
                            {{ include('membre/_form.html.twig', {'button_label': 'Sauvegarder'}) }}
                        {% endblock %}
                    </div>
                {% endblock %}
            </div>
        {% endblock %}
    </div>
{% endblock %}






