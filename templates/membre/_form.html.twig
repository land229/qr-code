<div class="nk-block nk-block-lg">
    <div class="card card-bordered">
        <div class="card-inner">
            {{ form_start(form) }}
            <div class="row g-gs">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.nom,'Nom du membre' ,{
                            'attr' : {
                                'class' : 'form-label',
                            }
                        }
                        ) }}
                        <div class="form-control-wrap">
                            {{ form_widget(form.nom,{
                                'required': false,
                                'attr' : {
                                    'class' : 'form-control',
                                    'placeholder':"Veuillez ecrire le nom"
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="form-group">
                        {{ form_label(form.prenom,'Prenom du membre' ,{
                            'attr' : {
                                'class' : 'form-label',
                            }
                        }
                        ) }}
                        <div class="form-control-wrap">
                            {{ form_widget(form.prenom,{
                                'required': false,
                                'attr' : {
                                    'class' : 'form-control',
                                    'placeholder':"Veuillez ecrire son prenom"
                                }
                            }) }}
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.telephone ,'Telephone' ,{
                            'attr' : {
                                'class' : 'form-label',
                            }
                        }
                        ) }}
                        <div class="form-control-wrap">
                            {{ form_widget(form.telephone,{
                                'required': false,
                                'attr' : {
                                    'class' : 'form-control form-select js-5select2',
                                    'data-search': 'onf',
                                    'placeholder':"Le Telephone"
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="form-group">
                        {{ form_label(form.email,'email du membre' ,{
                            'attr' : {
                                'class' : 'form-label',
                            }
                        }
                        ) }}
                        <div class="form-control-wrap">
                            {{ form_widget(form.email,{
                                'required': false,
                                'attr' : {
                                    'class' : 'form-control',
                                    'placeholder':"Veuillez ecrire son email"
                                }
                            }) }}
                        </div>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-group">
                        <button type="submit" class="btn btn-lg btn-primary">{{ button_label|default('Envoyer') }}</button>
                    </div>
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div><!-- .nk-block -->