{% extends 'base.html.twig' %}
{% block title %} connexion {% endblock %}
{% block sidebar %}{% endblock %}
{% block header %}{% endblock %}
{% block content_head %}{% endblock %}
{% block content %}
    <!-- content @s -->
    <div class="nk-content ">
        <div class="nk-block nk-block-middle nk-auth-body  wide-xs">
            <div class="card card-bordered shadow rounded-5">
                <div class="card-inner card-inner-lg">
                    <form method="post">
                        {% if error %}
                            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        {% endif %}

                        {% for message in app.flashes('notice') %}
                            <div class="alert alert-info"> {{ message }}</div>
                        {% endfor %}
                        <h1 class="h5 mb-3 text-center">Connexion</h1>
                        <div class="brand-logo pb-4 text-center">
                            <a href="#" class="logo-link">
                                <img class="logo-light logo-img"
                                     src="{{ asset("admin/images/logoifri.png") }}"
                                     alt="logo">
                                <img class="logo-dark logo-img"
                                     src="{{ asset("admin/images/logoifri.png") }}"
                                     alt="logo-dark">
                            </a>
                        </div>

                        <p class="text-center">🚀 Veuillez vous connecté SIG-Code Qr ! 💯</p>

{#                        {% if app.user %}#}
{#                            <div class="mb-3">#}
{#                                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('deconnexion') }}">se deconnecter</a>#}
{#                            </div>#}
{#                        {% endif %}#}
                        <div class="form-group">
                            <div class="form-control-wrap form-floating">
                                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" placeholder="Entrez votre adresse e-mail ou votre nom d'utilisateur" required autofocus>
                                <label class="form-label" for="inputEmail">E-mail ou nom d'utilisateur</label>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="form-label">
                                <a class="link link-primary link-sm" href="#">Mot de passe oublié?</a>
                            </div>
                            <div class="form-control-wrap form-floating">
                                <a href="#" class="form-icon form-icon-right passcode-switch lg h-100" data-target="inputPassword">
                                    <em class="passcode-icon icon-show icon ni ni-eye"></em>
                                    <em class="passcode-icon icon-hide icon ni ni-eye-off"></em>
                                </a>
                                <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" placeholder="Entre ton mot de passe" required>
                                <label class="form-label" for="inputPassword">Mot de passe</label>
                            </div>
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" >
                        </div>
                        <div class="form-group">
                            <div class="custom-control custom-control-xs custom-checkbox checked">
                                <input checked="" type="checkbox" name="_remember_me" class="custom-control-input" id="checkbox">
                                <label class="custom-control-label" for="checkbox">
                                    Se souvenir de
                                    <span class="text-primary">moi ✨</span>
                                </label>
                            </div>
                        </div>
                        <div class="form-group text-center">
                            <button class="btn btn-lg btn-primary" type="submit"> Se connecter </button>
                        </div>
                    </form>
                    <div class="form-note-s2 text-center pt-4"> Vous n'avez pas un compte ? <a href="{{ path("inscription") }}"> <strong>Creer un compte</strong> </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
