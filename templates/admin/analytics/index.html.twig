{% extends 'base.html.twig' %}

{% block title %}Analytics — {{ qr.titre }}{% endblock %}
{% block page_title %}Analytics{% endblock %}
{% block page_description %}Statistiques détaillées pour « {{ qr.titre }} »{% endblock %}

{% block actions %}
    <li>
        <a href="{{ path('admin_qr_list') }}" class="btn btn-white btn-dim btn-outline-primary">
            <em class="icon ni ni-arrow-left"></em>
            <span>Retour aux QR Codes</span>
        </a>
    </li>
    <li>
        <a href="{{ path('admin_analytics_global') }}" class="btn btn-white btn-dim btn-outline-secondary">
            <em class="icon ni ni-bar-chart"></em>
            <span>Vue globale</span>
        </a>
    </li>
{% endblock %}

{% block content_block %}
<style>
:root {
    --an-primary: #4f46e5; --an-primary-light: #e0e7ff;
    --an-success: #10b981; --an-warning: #f59e0b; --an-danger: #ef4444;
    --an-surface: #fff; --an-surface-2: #f8fafc;
    --an-border: #e2e8f0; --an-text: #0f172a; --an-muted: #64748b;
    --an-radius: 14px; --an-radius-sm: 9px;
}
.an-grid-top { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }
.an-stat { background:var(--an-surface); border:1px solid var(--an-border); border-radius:var(--an-radius); padding:18px 20px; }
.an-stat-label { font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.06em; color:var(--an-muted); margin-bottom:6px; }
.an-stat-val { font-size:26px; font-weight:900; color:var(--an-primary); line-height:1; }
.an-stat-sub { font-size:12px; color:var(--an-muted); margin-top:4px; }
.an-card { background:var(--an-surface); border:1px solid var(--an-border); border-radius:var(--an-radius); overflow:hidden; }
.an-card-head { padding:16px 20px; border-bottom:1px solid var(--an-border); display:flex; align-items:center; justify-content:space-between; }
.an-card-head h5 { margin:0; font-size:14px; font-weight:800; color:var(--an-text); display:flex; align-items:center; gap:8px; }
.an-card-body { padding:20px; }
.an-grid-charts { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px; }
.an-chart-wrap { position:relative; height:220px; }
.an-donut-wrap  { position:relative; height:220px; display:flex; align-items:center; justify-content:center; }
.an-legend { display:flex; flex-direction:column; gap:7px; margin-top:16px; }
.an-legend-item { display:flex; align-items:center; gap:8px; font-size:12.5px; color:var(--an-text); }
.an-legend-dot { width:11px; height:11px; border-radius:50%; flex-shrink:0; }
.an-table { width:100%; border-collapse:collapse; font-size:13px; }
.an-table th { text-align:left; padding:9px 12px; border-bottom:2px solid var(--an-border); font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.05em; color:var(--an-muted); }
.an-table td { padding:9px 12px; border-bottom:1px solid var(--an-border); color:var(--an-text); }
.an-table tr:last-child td { border-bottom:none; }
.an-table tr:hover td { background:var(--an-surface-2); }
.an-device-bar { display:flex; height:10px; border-radius:99px; overflow:hidden; margin-top:12px; }
.an-device-seg { transition:width .5s; }
.an-badge { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:99px; font-size:11px; font-weight:700; }
.an-badge-mobile  { background:#e0e7ff; color:#3730a3; }
.an-badge-desktop { background:#d1fae5; color:#065f46; }
.an-badge-tablet  { background:#fef3c7; color:#92400e; }
.an-badge-other   { background:#f1f5f9; color:#64748b; }
.an-empty { text-align:center; padding:40px; color:var(--an-muted); }
.an-empty em { font-size:36px; opacity:.3; }
@media(max-width:900px) { .an-grid-top { grid-template-columns:repeat(2,1fr); } .an-grid-charts { grid-template-columns:1fr; } }
</style>

{# ── KPIs ── #}
{% set total    = qr.compteurScans %}
{% set quota    = qr.quotaMaxScans %}
{% set devices  = deviceStats %}
{% set topBrow  = browserStats|keys|first %}

<div class="an-grid-top">
    <div class="an-stat">
        <div class="an-stat-label"><em class="icon ni ni-scan"></em> Total scans</div>
        <div class="an-stat-val">{{ total }}</div>
        <div class="an-stat-sub">{% if quota %}{{ quota - total }} restants{% else %}Illimité{% endif %}</div>
    </div>
    <div class="an-stat">
        <div class="an-stat-label"><em class="icon ni ni-mobile"></em> Mobile</div>
        <div class="an-stat-val">{{ devices.mobile }}</div>
        <div class="an-stat-sub">{% if total > 0 %}{{ ((devices.mobile / total) * 100)|round }}%{% else %}—{% endif %}</div>
    </div>
    <div class="an-stat">
        <div class="an-stat-label"><em class="icon ni ni-monitor"></em> Desktop</div>
        <div class="an-stat-val">{{ devices.desktop }}</div>
        <div class="an-stat-sub">{% if total > 0 %}{{ ((devices.desktop / total) * 100)|round }}%{% else %}—{% endif %}</div>
    </div>
    <div class="an-stat">
        <div class="an-stat-label"><em class="icon ni ni-globe"></em> Navigateur #1</div>
        <div class="an-stat-val" style="font-size:18px">{{ topBrow ?? '—' }}</div>
        <div class="an-stat-sub">{% if topBrow and total > 0 %}{{ ((browserStats[topBrow] / total) * 100)|round }}% des scans{% endif %}</div>
    </div>
</div>

{# ── Courbe des scans (30j) ── #}
<div class="an-card" style="margin-bottom:20px">
    <div class="an-card-head">
        <h5><em class="icon ni ni-trend-up"></em> Évolution des scans (30 derniers jours)</h5>
        <span style="font-size:12px;color:var(--an-muted)">Mis à jour en temps réel</span>
    </div>
    <div class="an-card-body">
        <div class="an-chart-wrap">
            <canvas id="chartLine"></canvas>
        </div>
    </div>
</div>

{# ── Appareils + Navigateurs ── #}
<div class="an-grid-charts">
    <div class="an-card">
        <div class="an-card-head"><h5><em class="icon ni ni-mobile"></em> Appareils</h5></div>
        <div class="an-card-body">
            <div class="an-donut-wrap"><canvas id="chartDevices"></canvas></div>
            {% if total > 0 %}
            <div class="an-device-bar" style="margin-top:16px">
                {% if devices.mobile > 0 %}
                    <div class="an-device-seg" style="width:{{ ((devices.mobile/total)*100)|round }}%;background:#4f46e5"></div>
                {% endif %}
                {% if devices.desktop > 0 %}
                    <div class="an-device-seg" style="width:{{ ((devices.desktop/total)*100)|round }}%;background:#10b981"></div>
                {% endif %}
                {% if devices.tablet > 0 %}
                    <div class="an-device-seg" style="width:{{ ((devices.tablet/total)*100)|round }}%;background:#f59e0b"></div>
                {% endif %}
                {% if devices.unknown > 0 %}
                    <div class="an-device-seg" style="width:{{ ((devices.unknown/total)*100)|round }}%;background:#e2e8f0"></div>
                {% endif %}
            </div>
            {% endif %}
            <div class="an-legend">
                <div class="an-legend-item"><div class="an-legend-dot" style="background:#4f46e5"></div> Mobile — <strong>{{ devices.mobile }}</strong></div>
                <div class="an-legend-item"><div class="an-legend-dot" style="background:#10b981"></div> Desktop — <strong>{{ devices.desktop }}</strong></div>
                <div class="an-legend-item"><div class="an-legend-dot" style="background:#f59e0b"></div> Tablette — <strong>{{ devices.tablet }}</strong></div>
            </div>
        </div>
    </div>

    <div class="an-card">
        <div class="an-card-head"><h5><em class="icon ni ni-globe"></em> Navigateurs</h5></div>
        <div class="an-card-body">
            <div class="an-donut-wrap"><canvas id="chartBrowsers"></canvas></div>
            <div class="an-legend" style="margin-top:16px">
                {% for name, count in browserStats %}
                <div class="an-legend-item">
                    <div class="an-legend-dot" style="background:{{ loop.index == 1 ? '#4f46e5' : loop.index == 2 ? '#06b6d4' : loop.index == 3 ? '#10b981' : loop.index == 4 ? '#f59e0b' : loop.index == 5 ? '#ef4444' : '#94a3b8' }}"></div>
                    {{ name }} — <strong>{{ count }}</strong>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{# ── Tableau des derniers scans ── #}
<div class="an-card">
    <div class="an-card-head">
        <h5><em class="icon ni ni-list-thumb"></em> Derniers scans</h5>
        <span style="font-size:12px;color:var(--an-muted)">{{ recentScans|length }} enregistrement(s)</span>
    </div>
    <div class="an-card-body" style="padding:0">
        {% if recentScans is empty %}
            <div class="an-empty">
                <em class="icon ni ni-scan"></em>
                <p style="margin:10px 0 0;font-size:13px;font-weight:600">Aucun scan enregistré</p>
            </div>
        {% else %}
            <div style="overflow-x:auto">
                <table class="an-table">
                    <thead>
                        <tr>
                            <th>Date & heure</th>
                            <th>IP</th>
                            <th>Appareil</th>
                            <th>Navigateur</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for scan in recentScans %}
                        <tr>
                            <td>{{ scan.dateHeure|date('d/m/Y H:i:s') }}</td>
                            <td><code style="font-size:12px">{{ scan.ipAdresse ?? '—' }}</code></td>
                            <td>
                                <span class="an-badge an-badge-{{ scan.appareil ?? 'other' }}">
                                    <em class="icon ni {{ scan.appareil == 'mobile' ? 'ni-mobile' : scan.appareil == 'desktop' ? 'ni-monitor' : scan.appareil == 'tablet' ? 'ni-tablet' : 'ni-question' }}"></em>
                                    {{ scan.appareil ?? 'Inconnu' }}
                                </span>
                            </td>
                            <td>{{ scan.navigateur ?? '—' }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

{# Chart.js #}
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const labels  = {{ labels|json_encode|raw }};
const values  = {{ values|json_encode|raw }};
const palette = ['#4f46e5','#06b6d4','#10b981','#f59e0b','#ef4444','#94a3b8'];

// ── Courbe 30j ────────────────────────────────────────────────────────
new Chart(document.getElementById('chartLine'), {
    type: 'line',
    data: {
        labels,
        datasets: [{
            label: 'Scans',
            data: values,
            borderColor: '#4f46e5',
            backgroundColor: 'rgba(79,70,229,.08)',
            borderWidth: 2.5,
            pointRadius: 3,
            pointBackgroundColor: '#4f46e5',
            fill: true,
            tension: 0.4,
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 11 } } },
            y: { beginAtZero: true, ticks: { precision: 0, font: { size: 11 } }, grid: { color: '#f1f5f9' } }
        }
    }
});

// ── Donut appareils ───────────────────────────────────────────────────
const devData = {{ deviceStats|json_encode|raw }};
new Chart(document.getElementById('chartDevices'), {
    type: 'doughnut',
    data: {
        labels: ['Mobile','Desktop','Tablette','Inconnu'],
        datasets: [{
            data: [devData.mobile, devData.desktop, devData.tablet, devData.unknown],
            backgroundColor: ['#4f46e5','#10b981','#f59e0b','#e2e8f0'],
            borderWidth: 2, borderColor: '#fff',
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: {
            label: ctx => ` ${ctx.label}: ${ctx.raw} (${Math.round(ctx.raw / ctx.dataset.data.reduce((a,b)=>a+b,0)*100)||0}%)`
        }}}
    }
});

// ── Donut navigateurs ─────────────────────────────────────────────────
const browData  = {{ browserStats|json_encode|raw }};
const browKeys  = Object.keys(browData);
const browVals  = Object.values(browData);
new Chart(document.getElementById('chartBrowsers'), {
    type: 'doughnut',
    data: {
        labels: browKeys,
        datasets: [{
            data: browVals,
            backgroundColor: palette.slice(0, browKeys.length),
            borderWidth: 2, borderColor: '#fff',
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } }
    }
});
</script>
{% endblock %}
