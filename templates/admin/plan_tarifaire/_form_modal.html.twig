<form method="POST" action="{{ route }}" novalidate>
    {{ form_widget(form._token) }}

    <div style="display:flex;flex-direction:column;gap:16px">

        <div>
            {{ form_label(form.nom, null, {label_attr: {class: 'qr-label'}}) }}
            {{ form_widget(form.nom) }}
            {{ form_errors(form.nom) }}
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div>
                {{ form_label(form.prix, null, {label_attr: {class: 'qr-label'}}) }}
                {{ form_widget(form.prix) }}
                {{ form_errors(form.prix) }}
            </div>
            <div>
                {{ form_label(form.limiteQR, null, {label_attr: {class: 'qr-label'}}) }}
                {{ form_widget(form.limiteQR) }}
                <small style="color:var(--pt-muted);font-size:11.5px">-1 = illimité</small>
                {{ form_errors(form.limiteQR) }}
            </div>
        </div>

        <div style="display:flex;align-items:center;gap:12px;padding:14px;
                    background:var(--pt-surface-2);border-radius:10px;
                    border:1.5px solid var(--pt-border)">
            {{ form_widget(form.accesAvance) }}
            <div>
                <div style="font-size:13.5px;font-weight:700;color:var(--pt-text)">
                    Accès aux fonctionnalités avancées
                </div>
                <div style="font-size:12px;color:var(--pt-muted)">
                    Analytics détaillés, export PDF, personnalisation complète
                </div>
            </div>
        </div>

    </div>

    <div style="display:flex;gap:10px;margin-top:24px;padding-top:20px;border-top:1px solid var(--pt-border)">
        <button type="button"
                onclick="closeModal('formModal')"
                style="flex:1;padding:11px;border-radius:9px;border:1px solid var(--pt-border);
                       background:var(--pt-surface-2);font-size:13.5px;font-weight:700;
                       cursor:pointer;color:var(--pt-muted)">
            Annuler
        </button>
        <button type="submit"
                style="flex:2;padding:11px;border-radius:9px;border:none;
                       background:linear-gradient(135deg,var(--pt-primary),var(--pt-accent));
                       color:#fff;font-size:13.5px;font-weight:700;cursor:pointer;
                       box-shadow:0 4px 14px rgba(79,70,229,.35)">
            <em class="icon ni ni-save"></em> Enregistrer
        </button>
    </div>
</form>