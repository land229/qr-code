{% extends 'base.html.twig' %}
{% block title %}QR Code inactif{% endblock %}
{% block body %}
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f8fafc">
    <div style="text-align:center;padding:40px;background:#fff;border-radius:16px;border:1px solid #e2e8f0;max-width:400px;width:90%">
        <div style="font-size:52px;margin-bottom:16px">😴</div>
        <h2 style="font-size:20px;font-weight:800;color:#0f172a;margin:0 0 8px">QR Code inactif</h2>
        <p style="color:#64748b;font-size:14px;margin:0">Ce QR code a été désactivé par son propriétaire.</p>
    </div>
</div>
{% endblock %}
